{
  "name": "lock-mint-relayer",
  "version": "1.0.0",
  "description": "Lock-and-mint bridge relayer: indexes lock events on OP Sepolia and mints on Base Sepolia via the ERC-7786 gateway.",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "pnpm run build:ts && tsc -p test/tsconfig.json && c8 node --env-file-if-exists=.env --import tsx --test --test-concurrency=1 --test-force-exit test/*.ts",
    "start": "pnpm run build:ts && fastify start -l info dist/app.js",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "dev": "pnpm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch:ts\" \"pnpm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js",
    "db:bootstrap": "node --env-file=.env --import tsx scripts/bootstrap-db.mts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "ferrodri",
  "license": "ISC",
  "packageManager": "pnpm@10.3.0",
  "engines": {
    "node": ">=24.18.0"
  },
  "dependencies": {
    "@fastify/autoload": "6.3.1",
    "@fastify/cors": "10.0.1",
    "@fastify/sensible": "6.0.4",
    "fastify": "5.8.5",
    "fastify-cli": "8.0.0",
    "fastify-plugin": "5.1.0",
    "fastify-type-provider-zod": "6.1.0",
    "kysely": "0.29.2",
    "pg": "8.21.0",
    "pino-pretty": "13.1.3",
    "viem": "2.51.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "c8": "11.0.0",
    "concurrently": "9.2.1",
    "fastify-tsconfig": "3.0.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  }
}
